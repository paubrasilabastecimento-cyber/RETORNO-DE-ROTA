{
  "entities": {
    "AppStateUsers": {
      "title": "AppStateUsers",
      "description": "Stored list of all registered system users and profiles",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of user records"
        }
      },
      "required": ["data"]
    },
    "AppStateDrivers": {
      "title": "AppStateDrivers",
      "description": "Stored list of all drivers and helpers",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of driver records"
        }
      },
      "required": ["data"]
    },
    "AppStateVehicles": {
      "title": "AppStateVehicles",
      "description": "Stored list of all logistics vehicles",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of vehicle records"
        }
      },
      "required": ["data"]
    },
    "AppStateProducts": {
      "title": "AppStateProducts",
      "description": "Product master data catalog",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of product catalog items"
        }
      },
      "required": ["data"]
    },
    "AppStateActiveAssets": {
      "title": "AppStateActiveAssets",
      "description": "Active asset catalog (returnable pallets, etc)",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of active assets"
        }
      },
      "required": ["data"]
    },
    "AppStateAudits": {
      "title": "AppStateAudits",
      "description": "Sessions and audits of returned routes",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of audit sessions"
        }
      },
      "required": ["data"]
    },
    "AppStateVales": {
      "title": "AppStateVales",
      "description": "Drawn vales for deficits and missing cargo",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of vales"
        }
      },
      "required": ["data"]
    },
    "AppStateReturnForecasts": {
      "title": "AppStateReturnForecasts",
      "description": "Trip monitor ETAs and pernoite states",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of return forecasts"
        }
      },
      "required": ["data"]
    },
    "AppStateFiscalAlerts": {
      "title": "AppStateFiscalAlerts",
      "description": "Urgent notifications and operational fiscal alerts",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of fiscal alerts"
        }
      },
      "required": ["data"]
    },
    "AppStateImportedRoutes": {
      "title": "AppStateImportedRoutes",
      "description": "Planilha/Imported routes pending counting",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of imported routes"
        }
      },
      "required": ["data"]
    },
    "AppStatePhotos": {
      "title": "AppStatePhotos",
      "description": "Photographic records captured during physical count",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "description": "List of physical photo items with audit references"
        }
      },
      "required": ["data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "AppStateUsers",
      "description": "User profiles collection"
    },
    "/drivers/{driverId}": {
      "schema": "AppStateDrivers",
      "description": "Drivers and helpers collection"
    },
    "/vehicles/{vehicleId}": {
      "schema": "AppStateVehicles",
      "description": "Vehicles collection"
    },
    "/products/{productId}": {
      "schema": "AppStateProducts",
      "description": "Product catalog collection"
    },
    "/activeAssets/{assetId}": {
      "schema": "AppStateActiveAssets",
      "description": "Active assets collection"
    },
    "/audits/{auditId}": {
      "schema": "AppStateAudits",
      "description": "Audits collection"
    },
    "/vales/{valeId}": {
      "schema": "AppStateVales",
      "description": "Vales collection"
    },
    "/returnForecasts/{forecastId}": {
      "schema": "AppStateReturnForecasts",
      "description": "Return forecasts collection"
    },
    "/fiscalAlerts/{alertId}": {
      "schema": "AppStateFiscalAlerts",
      "description": "Fiscal alerts collection"
    },
    "/importedRoutes/{routeId}": {
      "schema": "AppStateImportedRoutes",
      "description": "Imported routes collection"
    },
    "/auditLogs/{logId}": {
      "schema": "AppStateAudits",
      "description": "Audit logs collection"
    },
    "/customManual/main": {
      "schema": "AppStateAudits",
      "description": "Custom manual document"
    },
    "/app_state/{docId}": {
      "schema": "AppStateAudits",
      "description": "Legacy app_state"
    },
    "/photos/{photoId}": {
      "schema": "AppStatePhotos",
      "description": "Recorded photos for refugo audits"
    }
  }
}
